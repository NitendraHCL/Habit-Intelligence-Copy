generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Auth & User Management ──

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  name         String
  avatarUrl    String?  @map("avatar_url")
  role         Role     @default(CLIENT_VIEWER)
  isActive     Boolean  @default(true) @map("is_active")
  clientId     String?  @map("client_id")
  lastLoginAt  DateTime? @map("last_login_at")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  client              Client?               @relation(fields: [clientId], references: [id])
  sessions            Session[]
  clientAssignments   UserClientAssignment[]
  annotations         DashboardAnnotation[]

  @@map("users")
}

model Session {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([expiresAt])
  @@map("sessions")
}

enum Role {
  SUPER_ADMIN
  INTERNAL_OPS
  KAM
  CLIENT_ADMIN
  CLIENT_VIEWER
}

// ── Client / Tenant ──

model Client {
  id              String   @id @default(uuid())
  cugId           String   @map("cug_id")
  cugCode         String?  @map("cug_code")
  cugName         String   @map("cug_name")
  logo            String?
  industry        String?
  hasOhc          Boolean  @default(false) @map("has_ohc")
  hasLsmp         Boolean  @default(false) @map("has_lsmp")
  hasNps          Boolean  @default(false) @map("has_nps")
  hasHabitApp     Boolean  @default(false) @map("has_habit_app")
  /// JSON array of page slugs this CUG can access, e.g.
  /// ["/portal/home", "/portal/ohc/utilization", ...].
  /// null = all pages visible (backwards compat for existing CUGs).
  enabledPages      Json?    @map("enabled_pages")
  /// When true, custom dashboards created for this CUG are visible by default.
  hasCustomDashboards Boolean @default(false) @map("has_custom_dashboards")
  aiProvider      String?  @map("ai_provider")
  aiContextNotes  String?  @map("ai_context_notes")
  metricOverrides   Json?    @map("metric_overrides")
  draftConfig       Json?    @map("draft_config")
  publishedConfig   Json?    @map("published_config")
  configPublishedAt DateTime? @map("config_published_at")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  users                User[]
  userAssignments      UserClientAssignment[]
  dashboardAnnotations DashboardAnnotation[]
  dashboardDefinitions DashboardDefinition[]

  @@map("clients")
}

model UserClientAssignment {
  id       String @id @default(uuid())
  userId   String @map("user_id")
  clientId String @map("client_id")
  role     Role   @default(KAM)

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([userId, clientId])
  @@map("user_client_assignments")
}


model DashboardAnnotation {
  id                 String      @id @default(uuid())
  clientId           String      @map("client_id")
  pageSlug           String      @map("page_slug")
  metricKey          String?     @map("metric_key")
  filterContext      Json?       @map("filter_context")
  commentText        String      @map("comment_text")
  commentType        CommentType @default(OBSERVATION) @map("comment_type")
  authorId           String      @map("author_id")
  isVisibleToClient  Boolean     @default(true) @map("is_visible_to_client")
  isPinned           Boolean     @default(false) @map("is_pinned")
  createdAt          DateTime    @default(now()) @map("created_at")
  updatedAt          DateTime    @updatedAt @map("updated_at")

  client Client @relation(fields: [clientId], references: [id])
  author User   @relation(fields: [authorId], references: [id])

  @@map("dashboard_annotations")
}

// ── No-Code Dashboard Builder ──

model DashboardDefinition {
  id          String    @id @default(uuid())
  clientId    String?   @map("client_id")
  slug        String
  title       String
  subtitle    String?
  icon        String    @default("BarChart3")
  navGroup    String    @default("Custom") @map("nav_group")
  config      Json
  isDraft     Boolean   @default(true) @map("is_draft")
  publishedAt DateTime? @map("published_at")
  createdBy   String    @map("created_by")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  client   Client?            @relation(fields: [clientId], references: [id])
  versions DashboardVersion[]

  @@unique([clientId, slug])
  @@map("dashboard_definitions")
}

model DashboardVersion {
  id          String   @id @default(uuid())
  dashboardId String   @map("dashboard_id")
  version     Int
  config      Json
  title       String
  publishedBy String   @map("published_by")
  publishedAt DateTime @default(now()) @map("published_at")

  dashboard DashboardDefinition @relation(fields: [dashboardId], references: [id], onDelete: Cascade)

  @@unique([dashboardId, version])
  @@map("dashboard_versions")
}

model ChartDefinition {
  id         String   @id @default(uuid())
  name       String
  config     Json
  isTemplate Boolean  @default(false) @map("is_template")
  createdBy  String   @map("created_by")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@map("chart_definitions")
}

/// DS-1: Admin-editable data source registry. Replaces the hardcoded
/// lib/config/data-sources.ts whitelist — Super Admins can add/edit tables
/// and columns through the /portal/admin/data-sources UI without a deploy.
model DataSourceRegistry {
  id         String   @id @default(uuid())
  table      String   @unique
  label      String
  cugColumn  String   @map("cug_column")
  columns    Json
  joins      Json?
  enabled    Boolean  @default(true)
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@map("data_source_registry")
}

// ── Enums ──

enum CommentType {
  OBSERVATION
  RECOMMENDATION
  ACTION_ITEM
  HIGHLIGHT
}
